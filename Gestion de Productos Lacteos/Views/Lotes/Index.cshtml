@model IEnumerable<Gestion_de_Productos_Lacteos.Models.Lote>

@{
    ViewData["Title"] = "Gestión de Lotes";
}

<style>
    /* Diseño de doble borde azul para Panel de Filtros y Modal */
    .double-border-blue {
        border: 5px double #0d6efd !important;
        border-radius: 15px;
        background-color: #ffffff;
    }

    .filter-panel {
        background-color: #f8f9fa;
        padding: 20px;
    }

    .form-control-sm:focus, .form-select-sm:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }
</style>

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold">
                <i class="fas fa-layer-group text-primary me-2"></i>Control de Lotes
            </h4>
            <small class="text-muted">Gestión inteligente de stock y caducidad</small>
        </div>
        <button onclick="abrirModal(0)" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> Nuevo Lote
        </button>
    </div>

    <div class="card double-border-blue shadow-sm mb-4">
        <div class="card-body filter-panel">
            <form id="formFiltros" method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-primary">
                        <i class="fas fa-search me-1"></i> Búsqueda rápida
                    </label>
                    <input type="text" name="buscar" id="buscar" class="form-control form-control-sm"
                           placeholder="Lote o producto..." value="@ViewBag.BuscarActual">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-primary">
                        <i class="fas fa-box me-1"></i> Producto
                    </label>
                    <select name="idProducto" id="idProducto" class="form-select form-select-sm" asp-items="ViewBag.IdProducto">
                        <option value="">-- Todos los productos --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-primary">
                        <i class="fas fa-info-circle me-1"></i> Estado
                    </label>
                    <select name="estado" id="estado" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="disponibles" selected="@(ViewBag.EstadoActual == "disponibles")">Disponibles</option>
                        <option value="vencidos" selected="@(ViewBag.EstadoActual == "vencidos")">Ya vencidos</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-primary">
                        <i class="fas fa-sort me-1"></i> Ordenar vencimiento
                    </label>
                    <select name="orden" id="orden" class="form-select form-select-sm">
                        <option value="fecha_asc" selected="@(ViewBag.OrdenActual == "fecha_asc")">Más próximos primero</option>
                        <option value="fecha_desc" selected="@(ViewBag.OrdenActual == "fecha_desc")">Más lejanos primero</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100" title="Limpiar todos los filtros">
                        <i class="fas fa-eraser"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small uppercase">
                        <tr>
                            <th class="ps-4">Producto</th>
                            <th>N° Lote</th>
                            <th>Vencimiento</th>
                            <th class="text-center">Stock</th>
                            <th>Estado</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="6" class="text-center py-5 text-muted small italic">No hay lotes que coincidan con la búsqueda activa.</td></tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.IdProductoNavigation?.NombreProducto</td>
                                <td><span class="badge bg-light text-primary border border-primary border-opacity-25">@item.NumeroLote</span></td>
                                <td class="small">@item.FechaVencimiento?.ToString("dd/MM/yyyy")</td>
                                <td class="text-center fw-bold">@item.Cantidad</td>
                                <td>
                                    @{
                                        var hoy = DateOnly.FromDateTime(DateTime.Now);
                                        var dias = item.FechaVencimiento.HasValue ? item.FechaVencimiento.Value.DayNumber - hoy.DayNumber : 0;
                                    }
                                    @if (dias < 0)
                                    {
                                        <span class="badge bg-dark bg-opacity-10 text-dark border border-dark px-2">VENCIDO</span>
                                    }
                                    else if (dias <= 7)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-2">@dias días</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2">@dias días</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <button onclick="abrirModal(@item.IdLote)" class="btn btn-sm btn-outline-primary border-0 shadow-sm">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    @if (dias >= 0)
                                    {
                                        <button onclick="marcarVencido(@item.IdLote, '@item.NumeroLote')" class="btn btn-sm btn-outline-secondary border-0 shadow-sm">
                                            <i class="fas fa-hourglass-end"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLote" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content double-border-blue">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-primary" id="tituloModal">
                    <i class="fas fa-layer-group me-2"></i><span>Nuevo Lote</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formLote">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="IdLote" name="IdLote" value="0" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-primary">Producto</label>
                        <select id="IdProducto" name="IdProducto" class="form-select border-primary border-opacity-25" required>
                            <option value="">-- Seleccionar producto --</option>
                            @if (ViewBag.IdProducto != null)
                            {
                                foreach (var prod in (IEnumerable<SelectListItem>)ViewBag.IdProducto)
                                {
                                    <option value="@prod.Value">@prod.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">Código Lote</label>
                            <input type="text" id="NumeroLote" name="NumeroLote" class="form-control border-primary border-opacity-25" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">Cantidad Inicial</label>
                            <input type="number" id="Cantidad" name="Cantidad" class="form-control border-primary border-opacity-25" required min="1" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">F. Producción</label>
                            <input type="date" id="FechaProduccion" name="FechaProduccion" class="form-control border-primary border-opacity-25" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">F. Vencimiento</label>
                            <input type="date" id="FechaVencimiento" name="FechaVencimiento" class="form-control border-primary border-opacity-25" required />
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="button" onclick="guardarLote()" class="btn btn-primary fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i>Guardar Lote
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Búsqueda Activa Automática
        const formFiltros = document.getElementById('formFiltros');
        const inputsFiltro = formFiltros.querySelectorAll('select, input');

        inputsFiltro.forEach(input => {
            input.addEventListener(input.tagName === 'SELECT' ? 'change' : 'input', () => {
                clearTimeout(this.delay);
                this.delay = setTimeout(() => {
                    formFiltros.submit();
                }, 400);
            });
        });

        // Lógica de Modal y CRUD
        const modalLote = new bootstrap.Modal(document.getElementById('modalLote'));

        function abrirModal(id) {
            document.getElementById('formLote').reset();
            document.getElementById('IdLote').value = id;
            if (id === 0) {
                document.getElementById('tituloModal').querySelector('span').innerText = "Nuevo Lote";
                modalLote.show();
            } else {
                document.getElementById('tituloModal').querySelector('span').innerText = "Editar Lote";
                fetch(`/Lotes/GetLote/${id}`).then(res => res.json()).then(data => {
                    document.getElementById('IdProducto').value = data.idProducto;
                    document.getElementById('NumeroLote').value = data.numeroLote;
                    document.getElementById('Cantidad').value = data.cantidad;
                    document.getElementById('FechaProduccion').value = data.fechaProduccion;
                    document.getElementById('FechaVencimiento').value = data.fechaVencimiento;
                    modalLote.show();
                });
            }
        }

        function guardarLote() {
            const form = document.getElementById('formLote');
            if (!form.checkValidity()) { form.reportValidity(); return; }
            const formData = new FormData(form);
            fetch('/Lotes/Save', { method: 'POST', body: formData })
                .then(res => res.json()).then(data => { if (data.success) location.reload(); });
        }

        function marcarVencido(id, numero) {
            Swal.fire({
                title: '¿Marcar vencido?',
                text: `El lote ${numero} será retirado del inventario activo.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#6c757d',
                confirmButtonText: 'Confirmar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post(`/Lotes/MarcarComoVencido/${id}`, () => location.reload());
                }
            });
        }
    </script>
}