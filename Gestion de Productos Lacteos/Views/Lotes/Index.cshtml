@model IEnumerable<Gestion_de_Productos_Lacteos.Models.Lote>

@{
    ViewData["Title"] = "Gestión de Lotes";
}

<style>
    .double-border-blue {
        border: 5px double #0d6efd !important;
        border-radius: 15px;
        background-color: #ffffff;
    }

    .filter-panel {
        background-color: #f8f9fa;
        padding: 20px;
    }

    .producto-deshabilitado {
        opacity: 0.6;
        background-color: #fcfcfc;
    }
</style>

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold"><i class="fas fa-layer-group text-primary me-2"></i>Control de Lotes</h4>
            <small class="text-muted">Gestión de existencias, precios y trazabilidad de auditoría</small>
        </div>
        <button onclick="abrirModal(0)" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> Nuevo Lote
        </button>
    </div>

    <div class="card double-border-blue shadow-sm mb-4">
        <div class="card-body filter-panel">
            <form id="formFiltros" method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-primary"><i class="fas fa-search me-1"></i> Búsqueda rápida</label>
                    <input type="text" name="buscar" id="buscar" class="form-control form-control-sm" placeholder="Lote, producto o desc..." value="@ViewBag.BuscarActual">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-primary"><i class="fas fa-box me-1"></i> Producto</label>
                    <select name="idProducto" id="idProductoFiltro" class="form-select form-select-sm" asp-items="ViewBag.IdProducto">
                        <option value="">-- Todos los productos activos --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-primary"><i class="fas fa-info-circle me-1"></i> Estado</label>
                    <select name="estado" id="estado" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="disponibles" selected="@(ViewBag.EstadoActual == "disponibles")">Disponibles</option>
                        <option value="vencidos" selected="@(ViewBag.EstadoActual == "vencidos")">Ya vencidos</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-primary"><i class="fas fa-sort me-1"></i> Ordenar vencimiento</label>
                    <select name="orden" id="orden" class="form-select form-select-sm">
                        <option value="fecha_asc" selected="@(ViewBag.OrdenActual == "fecha_asc")">Más próximos primero</option>
                        <option value="fecha_desc" selected="@(ViewBag.OrdenActual == "fecha_desc")">Más lejanos primero</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100" title="Limpiar filtros"><i class="fas fa-eraser"></i></a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-light text-muted small uppercase">
                        <tr>
                            <th class="ps-4 text-start">Producto</th>
                            <th>N° Lote</th>
                            <th>Proveedor</th>
                            <th>F. Ingreso</th>
                            <th>Stock</th>
                            <th>PVP (Factura)</th>
                            <th>Vencimiento</th>
                            <th>Estado</th>
                            <th>Última Modif.</th>
                            <th class="pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="10" class="text-center py-5 text-muted">No se encontraron lotes registrados.</td></tr>
                        }
                        @foreach (var item in Model)
                        {
                            var esInactivo = item.ProductoNavigation?.Estado == false;
                            var hoy = DateTime.Today;
                            var dias = item.FechaVencimiento.HasValue ? (item.FechaVencimiento.Value.Date - hoy).Days : 0;

                            string claseFila = "";
                            if (esInactivo) claseFila = "producto-deshabilitado";

                            <tr class="@claseFila">
                                <td class="ps-4 text-start">
                                    <span class="fw-bold">@item.ProductoNavigation?.NombreProducto</span>
                                    @if (esInactivo)
                                    {
                                        <small class="text-danger d-block" style="font-size: 10px;">(DESHABILITADO)</small>
                                    }
                                </td>
                                <td><span class="badge bg-light text-primary border">@item.NumeroLote</span></td>
                                <td><small class="fw-semibold text-secondary">@(item.IdProveedorNavigation?.NombreProveedor ?? "Sin Asignar")</small></td>
                                <td class="small">@item.FechaIngreso?.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="fw-bold @(item.Cantidad == 0 ? "text-danger" : "")">@item.Cantidad</span>
                                </td>
                                <td>
                                    <span class="fw-bold text-success">$@item.PrecioFactura.ToString("N2")</span>
                                </td>
                                <td class="small">@item.FechaVencimiento?.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Cantidad <= 0)
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2">AGOTADO</span>
                                    }
                                    else if (dias < 0)
                                    {
                                        <span class="badge bg-dark bg-opacity-10 text-dark border border-dark px-2">VENCIDO</span>
                                    }
                                    else if (dias <= 7)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-2">@dias días</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2">@dias días</span>
                                    }
                                </td>
                                <td>
                                    <small class="text-muted" style="font-size: 11px;">
                                        @(item.UltimaModificacion?.ToString("dd/MM/yyyy hh:mm tt") ?? "Original")
                                    </small>
                                </td>
                                <td class="pe-4">
                                    <button onclick="abrirModal(@item.IdLote)" class="btn btn-sm btn-outline-primary border-0"><i class="fas fa-edit"></i></button>
                                    @if (dias >= 0 && item.Cantidad > 0)
                                    {
                                        <button onclick="marcarVencido(@item.IdLote, '@item.NumeroLote')" class="btn btn-sm btn-outline-secondary border-0" title="Marcar como vencido manual"><i class="fas fa-hourglass-end"></i></button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLote" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content double-border-blue">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-primary" id="tituloModal"><i class="fas fa-layer-group me-2"></i><span>Nuevo Lote</span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formLote">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="IdLote" name="IdLote" value="0" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">Producto</label>
                            <select id="IdProducto" name="IdProducto" class="form-select" required>
                                <option value="">-- Seleccionar producto activo --</option>
                                @foreach (var prod in (IEnumerable<SelectListItem>)ViewBag.IdProducto)
                                {
                                    <option value="@prod.Value">@prod.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">Descripción del Lote (Opcional)</label>
                            <input type="text" id="Descripcion" name="Descripcion" class="form-control" placeholder="Ej: Empaque promocional..." />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">Código Lote</label>
                            <input type="text" id="NumeroLote" name="NumeroLote" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">Cantidad Actual</label>
                            <input type="number" id="Cantidad" name="Cantidad" class="form-control" required min="0" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">F. Producción</label>
                            <input type="date" id="FechaProduccion" name="FechaProduccion" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-primary">F. Vencimiento</label>
                            <input type="date" id="FechaVencimiento" name="FechaVencimiento" class="form-control" required />
                        </div>
                    </div>

                    <h6 class="text-primary fw-bold mt-3 border-bottom pb-2"><i class="fas fa-shield-alt me-2"></i>Auditoría de Entrada y Costos</h6>
                    <div class="row bg-light p-3 rounded mb-3 border">
                        <div class="col-md-5 mb-2">
                            <label class="form-label small fw-bold text-primary">Proveedor Relacionado</label>
                            <select id="IdProveedor" name="IdProveedor" class="form-select" asp-items="ViewBag.IdProveedor">
                                <option value="">-- Seleccionar Proveedor de Catálogo --</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold text-primary">Fecha de Ingreso</label>
                            <input type="date" id="FechaIngreso" name="FechaIngreso" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label small fw-bold text-primary">Costo de Compra ($)</label>
                            <input type="number" id="CostoCompra" name="CostoCompra" class="form-control" step="0.0001" placeholder="Ej: 0.6500" />
                        </div>
                    </div>

                    <h6 class="text-primary fw-bold mt-3 border-bottom pb-2"><i class="fas fa-file-invoice-dollar me-2"></i>Desglose de Precios (IVA 13%)</h6>
                    <div class="row bg-light p-3 rounded mb-3 border">
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold text-primary">Vta Neta ($)</label>
                            <input type="number" id="VtaNeta" name="VtaNeta" class="form-control fw-bold text-primary" step="0.0001" placeholder="Ej: 0.91" required />
                            <small class="text-muted" style="font-size: 0.7rem;">(Precio base)</small>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold text-muted">IVA (13%)</label>
                            <input type="number" id="IvaConsumidor" name="IvaConsumidor" class="form-control bg-white" step="0.0001" readonly tabindex="-1" />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold text-muted">CCF s/IVA ($)</label>
                            <input type="number" id="CcfSiva" name="CcfSiva" class="form-control bg-white" step="0.0001" readonly tabindex="-1" />
                        </div>
                        <div class="col-md-6 mt-2">
                            <label class="form-label small fw-bold text-muted">IVA Contribuyente (13%)</label>
                            <input type="number" id="IvaContribuyente" name="IvaContribuyente" class="form-control bg-white" step="0.0001" readonly tabindex="-1" />
                        </div>
                        <div class="col-md-6 mt-2">
                            <label class="form-label small fw-bold text-success">Total Factura (PVP)</label>
                            <input type="number" id="PrecioFactura" name="PrecioFactura" class="form-control bg-white fw-bold text-success" step="0.0001" readonly tabindex="-1" />
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="button" onclick="guardarLote()" class="btn btn-primary fw-bold shadow-sm py-2"><i class="fas fa-save me-2"></i>Guardar Lote</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- Filtros ---
        const formFiltros = document.getElementById('formFiltros');
        formFiltros.querySelectorAll('select, input').forEach(input => {
            input.addEventListener(input.tagName === 'SELECT' ? 'change' : 'input', function () {
                clearTimeout(this.delay);
                this.delay = setTimeout(() => formFiltros.submit(), 400);
            });
        });

        // --- Lógica del Cálculo de IVA ---
        document.getElementById('VtaNeta').addEventListener('input', calcularPrecios);
        function calcularPrecios() {
            let vtaNeta = parseFloat(document.getElementById('VtaNeta').value) || 0;
            let iva = vtaNeta * 0.13;
            let totalConsumidor = vtaNeta + iva;

            document.getElementById('IvaConsumidor').value = iva.toFixed(4);
            document.getElementById('CcfSiva').value = totalConsumidor.toFixed(4);

            let ivaCCF = totalConsumidor * 0.13;
            document.getElementById('IvaContribuyente').value = ivaCCF.toFixed(4);

            let precioFactura = totalConsumidor + ivaCCF;
            document.getElementById('PrecioFactura').value = precioFactura.toFixed(4);
        }

        // --- Modales y CRUD ---
        const modalLote = new bootstrap.Modal(document.getElementById('modalLote'));

        function abrirModal(id) {
            document.getElementById('formLote').reset();
            document.getElementById('IdLote').value = id;

            if (id === 0) {
                document.getElementById('tituloModal').querySelector('span').innerText = "Nuevo Lote";
                // Asignar por defecto la fecha de hoy al crear uno nuevo
                document.getElementById('FechaIngreso').value = new Date().toISOString().split('T')[0];
                modalLote.show();
            } else {
                document.getElementById('tituloModal').querySelector('span').innerText = "Editar Lote";
                fetch(`/Lotes/GetLote/${id}`).then(res => res.json()).then(data => {
                    document.getElementById('IdProducto').value = data.idProducto;
                    document.getElementById('NumeroLote').value = data.numeroLote;
                    document.getElementById('Descripcion').value = data.descripcion || '';
                    document.getElementById('Cantidad').value = data.cantidad;
                    document.getElementById('FechaProduccion').value = data.fechaProduccion;
                    document.getElementById('FechaVencimiento').value = data.fechaVencimiento;

                    // Asignación de los nuevos campos de auditoría
                    document.getElementById('IdProveedor').value = data.idProveedor || '';
                    document.getElementById('FechaIngreso').value = data.fechaIngreso;
                    document.getElementById('CostoCompra').value = data.costoCompra;

                    // Cargar Precios
                    document.getElementById('VtaNeta').value = data.vtaNeta;
                    document.getElementById('IvaConsumidor').value = data.ivaConsumidor;
                    document.getElementById('CcfSiva').value = data.ccfSiva;
                    document.getElementById('IvaContribuyente').value = data.ivaContribuyente;
                    document.getElementById('PrecioFactura').value = data.precioFactura;

                    modalLote.show();
                });
            }
        }

        function guardarLote() {
            const form = document.getElementById('formLote');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            fetch('/Lotes/Save', { method: 'POST', body: new FormData(form) })
                .then(res => res.json()).then(data => {
                    if (data.success) location.reload();
                    else Swal.fire('Error', data.message, 'error');
                });
        }

        function marcarVencido(id, numero) {
            Swal.fire({
                title: '¿Marcar vencido?',
                text: `El lote ${numero} será retirado del inventario activo.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#6c757d',
                confirmButtonText: 'Confirmar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post(`/Lotes/MarcarComoVencido/${id}`, (res) => {
                        if (res.success) location.reload();
                        else Swal.fire('Error', res.message, 'error');
                    });
                }
            });
        }
    </script>
}